{
  "name": "airyfs-worker",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --local --name airyfs-local --persist-to ../.airyfs/local",
    "deploy:check": "node ../scripts/deploy.mjs check",
    "deploy": "node ../scripts/deploy.mjs deploy",
    "deploy:int": "node ../scripts/deploy.mjs deploy int",
    "deploy:prod": "node ../scripts/deploy.mjs deploy prod",
    "test:deploy": "node --test ../scripts/deploy.test.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "benchmark:chunks": "vitest bench --run bench/chunk-size.bench.ts"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.2.0",
    "agentfs-sdk": "file:../agentfs/.build/sdk/typescript",
    "buffer": "^6.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.14.0"
  }
}
