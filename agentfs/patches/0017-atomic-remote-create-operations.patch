+    async fn remote_create_node(
+        &self, conn: &Connection, kind: &str, parent_ino: i64, name: &str, mode: u32,
+        uid: u32, gid: u32, rdev: u64, target: &str, now_secs: i64, now_nsec: i64,
+    ) -> Result<i64> {
+        let mut rows = conn.query(
+            "SELECT airyfs_create_node_v1(?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
+            (kind, parent_ino, name, mode as i64, uid, gid, rdev as i64, target, now_secs, now_nsec),
+        ).await?;
+        let status = rows.next().await?
+            .and_then(|row| row.get_value(0i32).ok())
+            .and_then(|value| value.as_integer().copied())
+            .ok_or_else(|| Error::Internal("remote create returned no status".to_string()))?;
+        match status {
+            1.. => Ok(status),
+            0 => Err(FsError::AlreadyExists.into()),
+            -1 => Err(FsError::NotFound.into()),
+            _ => Err(Error::Internal(format!("invalid remote create status: {status}"))),
+        }
+    }
+
+    async fn remote_link(
+        &self, conn: &Connection, ino: i64, parent_ino: i64, name: &str,
+        now_secs: i64, now_nsec: i64,
+    ) -> Result<()> {
+        let mut rows = conn.query(
+            "SELECT airyfs_link_v1(?, ?, ?, ?, ?)",
+            (ino, parent_ino, name, now_secs, now_nsec),
+        ).await?;
+        let status = rows.next().await?
+            .and_then(|row| row.get_value(0i32).ok())
+            .and_then(|value| value.as_integer().copied())
+            .ok_or_else(|| Error::Internal("remote link returned no status".to_string()))?;
+        match status {
+            1.. => Ok(()),
+            0 => Err(FsError::AlreadyExists.into()),
+            -1 => Err(FsError::NotFound.into()),
+            -2 => Err(FsError::IsADirectory.into()),
+            _ => Err(Error::Internal(format!("invalid remote link status: {status}"))),
+        }
+    }
