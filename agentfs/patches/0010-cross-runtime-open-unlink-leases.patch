+#[cfg(test)]
+mod tests {
+    use super::*;
+    use std::time::Instant;
+
+    #[test]
+    fn lease_should_abort_only_after_sustained_failure() {
+        let limit = Duration::from_millis(50);
+        // No failure recorded yet: never abort.
+        assert!(!lease_should_abort(None, limit));
+        // A failure that just started has not yet exceeded the limit.
+        assert!(!lease_should_abort(Some(Instant::now()), limit));
+        // A failure that began before the limit window elapsed must abort.
+        let old = Instant::now() - Duration::from_millis(100);
+        assert!(lease_should_abort(Some(old), limit));
+    }
+
+    #[test]
+    fn duration_from_env_prefers_valid_override() {
+        let var = "AGENTFS_TEST_LEASE_DURATION_OVERRIDE";
+        // Unset -> default.
+        std::env::remove_var(var);
+        assert_eq!(duration_from_env(var, Duration::from_secs(120)), Duration::from_secs(120));
+        // Valid override -> parsed value.
+        std::env::set_var(var, "30");
+        assert_eq!(duration_from_env(var, Duration::from_secs(120)), Duration::from_secs(30));
+        // Zero and garbage fall back to the default (never weaker than intended).
+        std::env::set_var(var, "0");
+        assert_eq!(duration_from_env(var, Duration::from_secs(120)), Duration::from_secs(120));
+        std::env::set_var(var, "not-a-number");
+        assert_eq!(duration_from_env(var, Duration::from_secs(120)), Duration::from_secs(120));
+        std::env::remove_var(var);
+    }
+}
