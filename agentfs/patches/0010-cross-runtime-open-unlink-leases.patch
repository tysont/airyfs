+/// Renew active handle leases on a heartbeat and reap expired orphaned inodes.
+///
+/// Runs on its own connection (established synchronously before the mount was
+/// reported ready) so lease traffic never contends with the FUSE session's
+/// request pipeline. If renewal fails continuously for `failure_abort` (kept well
+/// below the lease TTL), the process aborts so a live handle can never outlast its
+/// lease and have its inode reaped from under it; the container command server
+/// then reports the mount unhealthy. On a clean shutdown it releases the whole
+/// session so no retained inodes leak.
+#[allow(clippy::too_many_arguments)]
+fn run_lease_heartbeat(
+    runtime: Runtime,
+    agentfs: AgentFS,
+    session_id: String,
+    open_files: Arc<Mutex<HashMap<u64, OpenFile>>>,
+    lease_ttl: Duration,
+    heartbeat_interval: Duration,
+    failure_abort: Duration,
+    running: Arc<AtomicBool>,
+) {
+    let mut first_failure: Option<std::time::Instant> = None;
+
+    while running.load(Ordering::Relaxed) {
+        // Sleep in short ticks so shutdown stays responsive.
+        let mut waited = Duration::ZERO;
+        while waited < heartbeat_interval && running.load(Ordering::Relaxed) {
+            let tick = Duration::from_millis(500);
+            thread::sleep(tick);
+            waited += tick;
+        }
+        if !running.load(Ordering::Relaxed) {
+            break;
+        }
+
+        let inos: Vec<i64> = {
+            let open_files = open_files.lock();
+            open_files
+                .values()
+                .filter_map(|open_file| open_file.lease_ino)
+                .collect()
+        };
+        let expires_at = lease_expiry(lease_ttl);
+
+        let result = runtime.block_on(async {
+            agentfs
+                .fs
+                .renew_open_leases(&session_id, &inos, expires_at)
+                .await?;
+            agentfs.fs.reap_expired_open_inodes().await?;
+            Ok::<(), SdkError>(())
+        });
+        match result {
+            Ok(()) => first_failure = None,
+            Err(error) => {
+                let since = *first_failure.get_or_insert_with(std::time::Instant::now);
+                tracing::warn!(
+                    "FUSE lease heartbeat failed (failing for {:?}): {error}",
+                    since.elapsed()
+                );
+                if lease_should_abort(first_failure, failure_abort) {
+                    tracing::error!(
+                        "FUSE lease renewal has failed for {:?} (>= {:?}); aborting mount to \
+                         avoid serving handles whose leases may have expired",
+                        since.elapsed(),
+                        failure_abort
+                    );
+                    // Terminate the whole process so the mount tears down and the
+                    // command server detects the dead FUSE daemon. This is the
+                    // conservative choice: kill the mount rather than risk reading
+                    // an inode another mount may reap once the lease expires.
+                    std::process::exit(LEASE_ABORT_EXIT_CODE);
+                }
+            }
+        }
+    }
+
+    // Graceful shutdown: drop every lease this session held and reap anything it
+    // was keeping alive.
+    if let Err(error) = runtime.block_on(agentfs.fs.cleanup_open_session(&session_id)) {
+        tracing::debug!("FUSE lease session cleanup failed: {error}");
+    }
+}
