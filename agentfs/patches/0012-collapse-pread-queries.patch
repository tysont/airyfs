From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Tyson Trautmann <tysont@gmail.com>
Date: Sun, 19 Jul 2026 21:30:00 -0700
Subject: [PATCH] Collapse pread metadata and chunk queries

Return inode size with the requested chunk rows so each pread needs one remote
query instead of a size query followed by a chunk query. Preserve sparse-file,
EOF, and cross-chunk behavior.
---
 sdk/rust/src/filesystem/agentfs.rs | 86 +++++++++++++++++++++++---------------
 1 file changed, 57 insertions(+), 29 deletions(-)

diff --git a/sdk/rust/src/filesystem/agentfs.rs b/sdk/rust/src/filesystem/agentfs.rs
--- a/sdk/rust/src/filesystem/agentfs.rs
+++ b/sdk/rust/src/filesystem/agentfs.rs
@@ -85,23 +85,34 @@ pub struct AgentFSFile {
 #[async_trait]
 impl File for AgentFSFile {
     async fn pread(&self, offset: u64, size: u64) -> Result<Vec<u8>> {
+        if size == 0 {
+            return Ok(Vec::new());
+        }
+
         let conn = self.pool.get_connection().await?;
+        let chunk_size = self.chunk_size as u64;
+        let start_chunk = offset / chunk_size;
+        let end_chunk = offset.saturating_add(size).saturating_sub(1) / chunk_size;
 
-        // Get the file size to avoid returning data beyond EOF
-        let file_size = {
-            let size_stmt = conn
-                .prepare("SELECT size FROM fs_inode WHERE ino = ?")
-                .await?;
-            let mut size_rows = size_stmt.query([self.ino]).await?;
-            if let Some(row) = size_rows.next().await? {
-                row.get_value(0i32)
-                    .ok()
-                    .and_then(|v| v.as_integer().copied())
-                    .unwrap_or(0) as u64
-            } else {
-                0
-            }
+        let stmt = conn
+            .prepare(
+                "SELECT i.size, d.chunk_index, d.data \
+                 FROM fs_inode i \
+                 LEFT JOIN fs_data d ON d.ino = i.ino AND d.chunk_index >= ? AND d.chunk_index <= ? \
+                 WHERE i.ino = ? ORDER BY d.chunk_index",
+            )
+            .await?;
+        let mut rows = stmt
+            .query((start_chunk as i64, end_chunk as i64, self.ino))
+            .await?;
+        let Some(mut row) = rows.next().await? else {
+            return Ok(Vec::new());
         };
+        let file_size = row
+            .get_value(0i32)
+            .ok()
+            .and_then(|v| v.as_integer().copied())
+            .unwrap_or(0) as u64;
 
         // If offset is at or beyond EOF, return empty
         if offset >= file_size {
@@ -111,27 +122,20 @@ impl File for AgentFSFile {
         // Limit size to not exceed EOF
         let size = std::cmp::min(size, file_size - offset);
 
-        let chunk_size = self.chunk_size as u64;
-        let start_chunk = offset / chunk_size;
-        let end_chunk = (offset + size).saturating_sub(1) / chunk_size;
-
-        let stmt = conn
-            .prepare("SELECT chunk_index, data FROM fs_data WHERE ino = ? AND chunk_index >= ? AND chunk_index <= ? ORDER BY chunk_index")
-            .await?;
-        let mut rows = stmt
-            .query((self.ino, start_chunk as i64, end_chunk as i64))
-            .await?;
-
         let mut result = Vec::with_capacity(size as usize);
         let start_offset_in_chunk = (offset % chunk_size) as usize;
         let mut next_expected_chunk = start_chunk;
 
-        while let Some(row) = rows.next().await? {
+        loop {
             let chunk_index = row
-                .get_value(0i32)
+                .get_value(1i32)
                 .ok()
                 .and_then(|v| v.as_integer().copied())
-                .unwrap_or(0) as u64;
+                .map(|value| value as u64);
+
+            let Some(chunk_index) = chunk_index else {
+                break;
+            };
 
             // Fill gaps with zeros for sparse files
             while next_expected_chunk < chunk_index && result.len() < size as usize {
@@ -146,7 +150,7 @@ impl File for AgentFSFile {
                 next_expected_chunk += 1;
             }
 
-            if let Ok(Value::Blob(chunk_data)) = row.get_value(1i32) {
+            if let Ok(Value::Blob(chunk_data)) = row.get_value(2i32) {
                 let skip = if chunk_index == start_chunk {
                     start_offset_in_chunk
                 } else {
@@ -174,6 +178,10 @@ impl File for AgentFSFile {
                 }
             }
             next_expected_chunk = chunk_index + 1;
+            let Some(next_row) = rows.next().await? else {
+                break;
+            };
+            row = next_row;
         }
 
         // Fill any remaining space with zeros (for sparse file tail or missing chunks at end)
@@ -4528,6 +4536,26 @@ mod tests {
         Ok(())
     }
 
+    #[tokio::test]
+    async fn test_pread_sparse_across_missing_chunks() -> Result<()> {
+        let (fs, _dir) = create_test_fs().await?;
+        let chunk_size = fs.chunk_size();
+        let (_, file) = fs.create_file("/sparse.bin", DEFAULT_FILE_MODE, 0, 0).await?;
+        let payload = [1, 2, 3, 4];
+        let payload_offset = chunk_size * 2 + 5;
+        file.pwrite(payload_offset as u64, &payload).await?;
+
+        let offset = chunk_size - 3;
+        let size = chunk_size + 12;
+        let result = file.pread(offset as u64, size as u64).await?;
+        let mut expected = vec![0; size];
+        let payload_start = payload_offset - offset;
+        expected[payload_start..payload_start + payload.len()].copy_from_slice(&payload);
+        assert_eq!(result, expected);
+
+        Ok(())
+    }
+
     #[tokio::test]
     async fn test_pwrite_basic() -> Result<()> {
         let (fs, _dir) = create_test_fs().await?;
-- 
