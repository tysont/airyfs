diff --git a/sdk/rust/src/filesystem/mod.rs b/sdk/rust/src/filesystem/mod.rs
--- a/sdk/rust/src/filesystem/mod.rs
+++ b/sdk/rust/src/filesystem/mod.rs
@@ -86,6 +86,7 @@ pub const S_IFIFO: u32 = 0o010000; // FIFO (named pipe)
 pub const S_IFCHR: u32 = 0o020000; // Character device
 pub const S_IFBLK: u32 = 0o060000; // Block device
 pub const S_IFSOCK: u32 = 0o140000; // Socket
+const ROOT_INO: i64 = 1;

 // Default permissions
 pub const DEFAULT_FILE_MODE: u32 = S_IFREG | 0o644; // Regular file, rw-r--r--
@@ -138,6 +139,14 @@ pub struct DirEntry {
     pub stats: Stats,
 }

+/// Directory entries plus attributes for the directory and its parent.
+#[derive(Debug, Clone)]
+pub struct DirectoryListing {
+    pub directory: Stats,
+    pub parent: Stats,
+    pub entries: Vec<DirEntry>,
+}
+
 impl Stats {
     pub fn is_file(&self) -> bool {
         (self.mode & S_IFMT) == S_IFREG
@@ -218,6 +227,31 @@ pub trait FileSystem: Send + Sync {
     /// Returns `Ok(None)` if the directory does not exist.
     async fn readdir_plus(&self, ino: i64) -> Result<Option<Vec<DirEntry>>>;

+    /// List directory contents with the attributes needed for `.` and `..`.
+    async fn readdir_plus_with_directory_stats(
+        &self,
+        ino: i64,
+    ) -> Result<Option<DirectoryListing>> {
+        let Some(entries) = self.readdir_plus(ino).await? else {
+            return Ok(None);
+        };
+        let Some(directory) = self.getattr(ino).await? else {
+            return Ok(None);
+        };
+        let parent = if ino == ROOT_INO {
+            directory.clone()
+        } else {
+            self.getattr(ROOT_INO)
+                .await?
+                .unwrap_or_else(|| directory.clone())
+        };
+        Ok(Some(DirectoryListing {
+            directory,
+            parent,
+            entries,
+        }))
+    }
+
     /// Change file mode/permissions by inode.
     async fn chmod(&self, ino: i64, mode: u32) -> Result<()>;

