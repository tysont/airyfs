+    async fn readdir_plus_with_directory_stats(
+        &self,
+        ino: i64,
+    ) -> Result<Option<DirectoryListing>> {
+        let conn = self.pool.get_connection().await?;
+        let stmt = conn
+            .prepare(
+                "WITH directory AS (\
+                   SELECT i.ino, i.mode, i.nlink, i.uid, i.gid, i.size, i.atime, i.mtime, i.ctime, i.rdev, \
+                          i.atime_nsec, i.mtime_nsec, i.ctime_nsec, \
+                          COALESCE((SELECT parent_ino FROM fs_dentry WHERE ino = i.ino LIMIT 1), i.ino) AS parent_ino \
+                   FROM fs_inode i WHERE i.ino = ?\
+                 ) \
+                 SELECT d.ino, d.mode, d.nlink, d.uid, d.gid, d.size, d.atime, d.mtime, d.ctime, d.rdev, \
+                        d.atime_nsec, d.mtime_nsec, d.ctime_nsec, 0 AS entry_kind, '' AS name \
+                 FROM directory d \
+                 UNION ALL \
+                 SELECT p.ino, p.mode, p.nlink, p.uid, p.gid, p.size, p.atime, p.mtime, p.ctime, p.rdev, \
+                        p.atime_nsec, p.mtime_nsec, p.ctime_nsec, 1 AS entry_kind, '' AS name \
+                 FROM directory d JOIN fs_inode p ON p.ino = d.parent_ino \
+                 UNION ALL \
+                 SELECT i.ino, i.mode, i.nlink, i.uid, i.gid, i.size, i.atime, i.mtime, i.ctime, i.rdev, \
+                        i.atime_nsec, i.mtime_nsec, i.ctime_nsec, 2 AS entry_kind, e.name \
+                 FROM directory d JOIN fs_dentry e ON e.parent_ino = d.ino JOIN fs_inode i ON i.ino = e.ino \
+                 ORDER BY entry_kind, name",
+            )
+            .await?;
+        let mut rows = stmt.query([ino]).await?;
+        let mut directory = None;
+        let mut parent = None;
+        let mut entries = Vec::new();
+
+        while let Some(row) = rows.next().await? {
+            let stats = Self::build_stats_from_row(&row)?;
+            let entry_kind = row
+                .get_value(13i32)
+                .ok()
+                .and_then(|value| value.as_integer().copied())
+                .unwrap_or(-1);
+            match entry_kind {
+                0 => directory = Some(stats),
+                1 => parent = Some(stats),
+                2 => {
+                    let name = row
+                        .get_value(14i32)
+                        .ok()
+                        .and_then(|value| match value {
+                            Value::Text(name) => Some(name.clone()),
+                            _ => None,
+                        })
+                        .unwrap_or_default();
+                    if !name.is_empty() {
+                        entries.push(DirEntry { name, stats });
+                    }
+                }
+                _ => {}
+            }
+        }
+
+        let Some(directory) = directory else {
+            return Ok(None);
+        };
+        if !directory.is_directory() {
+            return Err(FsError::NotADirectory.into());
+        }
+        let parent = parent.unwrap_or_else(|| directory.clone());
+        Ok(Some(DirectoryListing {
+            directory,
+            parent,
+            entries,
+        }))
+    }
