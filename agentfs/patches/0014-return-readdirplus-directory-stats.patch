+    #[tokio::test]
+    async fn test_readdir_plus_returns_directory_and_parent_stats() -> Result<()> {
+        let (fs, _dir) = create_test_fs().await?;
+        fs.mkdir("/parent", 0, 0).await?;
+        fs.mkdir("/parent/child", 0, 0).await?;
+        let parent_ino = fs.resolve_path("/parent").await?.unwrap();
+        let child_ino = fs.resolve_path("/parent/child").await?.unwrap();
+
+        let root = fs
+            .readdir_plus_with_directory_stats(ROOT_INO)
+            .await?
+            .unwrap();
+        assert_eq!(root.directory.ino, ROOT_INO);
+        assert_eq!(root.parent.ino, ROOT_INO);
+
+        let child = fs
+            .readdir_plus_with_directory_stats(child_ino)
+            .await?
+            .unwrap();
+        assert_eq!(child.directory.ino, child_ino);
+        assert_eq!(child.parent.ino, parent_ino);
+        assert!(child.directory.is_directory());
+        assert!(child.parent.is_directory());
+
+        Ok(())
+    }
+
