+                        .await?
+                        .map(|row| row.get(0))
+                        .transpose()?
+                        .unwrap_or(0),
+                );
+                return Ok::<Vec<(i64, i64, String, Option<i64>)>, SdkError>(Vec::new());
+            }
+
+            let mut rows = conn
+                .query(
+                    "SELECT seq, parent_ino, name, ino
+                     FROM fs_mutation_journal WHERE seq > ? ORDER BY seq LIMIT 256",
+                    [last_seq.unwrap()],
+                )
+                .await?;
+            let mut entries = Vec::new();
+            while let Some(row) = rows.next().await? {
+                entries.push((row.get(0)?, row.get(1)?, row.get(2)?, row.get(3)?));
+            }
+            Ok(entries)
+        });
+
+        match result {
+            Ok(entries) => {
+                for (seq, parent_ino, name, _ino) in entries {
+                    notifier.inval_entry(parent_ino as u64, OsStr::new(&name));
+                    last_seq = Some(seq);
+                }
+            }
+            Err(error) => tracing::debug!("FUSE invalidation poll failed: {error}"),
+        }
+
+        thread::sleep(Duration::from_millis(100));
+    }
+}
