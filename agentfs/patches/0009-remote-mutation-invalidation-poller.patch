+fn poll_invalidations(options: AgentFSOptions, notifier: DeferredNotifier, running: Arc<AtomicBool>) {
+    let runtime = crate::get_runtime();
+    let agentfs = match runtime.block_on(AgentFS::open(options)) {
+        Ok(agentfs) => agentfs,
+        Err(error) => {
+            tracing::debug!("FUSE invalidation poll startup failed: {error}");
+            return;
+        }
+    };
+    let mut last_seq: Option<i64> = None;
+
+    while running.load(Ordering::Relaxed) {
+        let result = runtime.block_on(async {
