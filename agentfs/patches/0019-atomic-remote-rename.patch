+    async fn remote_rename(
+        &self, conn: &Connection, old_parent_ino: i64, old_name: &str,
+        new_parent_ino: i64, new_name: &str,
+    ) -> Result<i64> {
+        let dur = SystemTime::now().duration_since(UNIX_EPOCH)?;
+        let mut rows = conn.query(
+            "SELECT airyfs_rename_v1(?, ?, ?, ?, ?, ?)",
+            (
+                old_parent_ino, old_name, new_parent_ino, new_name,
+                dur.as_secs() as i64, dur.subsec_nanos() as i64,
+            ),
+        ).await?;
+        let status = rows.next().await?
+            .and_then(|row| row.get_value(0i32).ok())
+            .and_then(|value| value.as_integer().copied())
+            .ok_or_else(|| Error::Internal("remote rename returned no status".to_string()))?;
+        match status {
+            1.. => Ok(status),
+            -1 => Err(FsError::NotFound.into()),
+            -2 => Err(FsError::IsADirectory.into()),
+            -3 => Err(FsError::NotADirectory.into()),
+            -4 => Err(FsError::NotEmpty.into()),
+            -5 => Err(FsError::InvalidRename.into()),
+            -6 => Err(FsError::RootOperation.into()),
+            _ => Err(Error::Internal(format!("invalid remote rename status: {status}"))),
+        }
+    }
+
