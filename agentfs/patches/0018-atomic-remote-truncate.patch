+async fn remote_truncate(
+    conn: &Connection, ino: i64, new_size: u64, chunk_size: usize,
+) -> Result<()> {
+    let dur = SystemTime::now().duration_since(UNIX_EPOCH)?;
+    let mut rows = conn.query(
+        "SELECT airyfs_truncate_v1(?, ?, ?, ?, ?)",
+        (
+            ino,
+            new_size as i64,
+            chunk_size as i64,
+            dur.as_secs() as i64,
+            dur.subsec_nanos() as i64,
+        ),
+    ).await?;
+    let status = rows.next().await?
+        .and_then(|row| row.get_value(0i32).ok())
+        .and_then(|value| value.as_integer().copied())
+        .ok_or_else(|| Error::Internal("remote truncate returned no status".to_string()))?;
+    match status {
+        1.. => Ok(()),
+        -1 => Err(FsError::NotFound.into()),
+        _ => Err(Error::Internal(format!("invalid remote truncate status: {status}"))),
+    }
+}
