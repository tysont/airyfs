+    /// Create a new connection pool for a remote database.
+    ///
+    /// Connects to a remote libsql server (e.g., via Hrana protocol over WebSocket).
+    /// All queries are executed on the remote server — no local file is created.
+    ///
+    /// # Arguments
+    /// * `url` - Remote database URL (e.g., `ws://host:port`, `https://host`)
+    /// * `auth_token` - Authentication token for the remote server
+    pub async fn new_remote(url: &str, auth_token: &str) -> Result<Self> {
+        let db = libsql::Builder::new_remote(url.to_string(), auth_token.to_string())
+            .build()
+            .await
+            .map_err(|e| Error::Internal(format!("failed to connect to remote database: {e}")))?;
+        Ok(Self::with_timeout(db, DEFAULT_TIMEOUT))
+    }
+
