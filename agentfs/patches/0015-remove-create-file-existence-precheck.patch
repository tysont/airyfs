+    async fn orphan_inode_count(fs: &AgentFS) -> Result<i64> {
+        let conn = fs.get_connection().await?;
+        let mut rows = conn
+            .query(
+                "SELECT COUNT(*) FROM fs_inode i \
+                 LEFT JOIN fs_dentry d ON d.ino = i.ino \
+                 WHERE i.ino != ? AND d.ino IS NULL",
+                [ROOT_INO],
+            )
+            .await?;
+        Ok(rows
+            .next()
+            .await?
+            .and_then(|row| row.get_value(0i32).ok())
+            .and_then(|value| value.as_integer().copied())
+            .unwrap_or(0))
+    }
+
+    #[tokio::test]
+    async fn test_create_file_conflict_maps_to_eexist_without_orphan() -> Result<()> {
+        let (fs, _dir) = create_test_fs().await?;
+        fs.create_file("/same.txt", DEFAULT_FILE_MODE, 0, 0).await?;
+
+        let duplicate = fs.create_file("/same.txt", DEFAULT_FILE_MODE, 0, 0).await;
+        assert!(matches!(duplicate, Err(Error::Fs(FsError::AlreadyExists))));
+        assert_eq!(orphan_inode_count(&fs).await?, 0);
+        Ok(())
+    }
+
+    #[tokio::test]
+    async fn test_concurrent_create_file_has_one_winner_and_no_orphan() -> Result<()> {
+        let (fs, _dir) = create_test_fs().await?;
+        let first = fs.clone();
+        let second = fs.clone();
+        let (left, right) = tokio::join!(
+            FileSystem::create_file(&first, ROOT_INO, "race.txt", DEFAULT_FILE_MODE, 0, 0),
+            FileSystem::create_file(&second, ROOT_INO, "race.txt", DEFAULT_FILE_MODE, 0, 0),
+        );
+
+        let results = [left, right];
+        assert_eq!(results.iter().filter(|result| result.is_ok()).count(), 1);
+        assert_eq!(
+            results
+                .iter()
+                .filter(|result| matches!(result, Err(Error::Fs(FsError::AlreadyExists))))
+                .count(),
+            1,
+        );
+        assert_eq!(orphan_inode_count(&fs).await?, 0);
+        Ok(())
+    }
